<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mile on Bike | Arfat Aziz – Pakistan's Road Storyteller</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=Oswald:wght@300;400;500;700&family=Lora:ital,wght@0,400;1,600&display=swap" rel="stylesheet">
<style>
:root {
  --sky: #0ea5e9;
  --emerald: #10b981;
  --amber: #f59e0b;
  --crimson: #ef4444;
  --sundown: #f97316;
  --ink: #0c0f1a;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--ink);color:#fff;font-family:'Montserrat',sans-serif;font-weight:400;overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:18px 60px;display:flex;justify-content:space-between;align-items:center;background:linear-gradient(to bottom,rgba(12,15,26,.92),transparent);backdrop-filter:blur(4px);}
.nav-logo{font-family:'Oswald',sans-serif;font-size:26px;font-weight:700;color:#fff;text-decoration:none;}
.nav-logo span{color:var(--amber);}
.nav-links{display:flex;gap:32px;}
.nav-link{font-family:'Oswald',sans-serif;font-size:13px;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.75);text-decoration:none;transition:color .2s;}
.nav-link:hover{color:var(--amber);}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=85') center/cover no-repeat;transform:scale(1.08);animation:kenBurns 18s ease-in-out infinite alternate;}
@keyframes kenBurns{from{transform:scale(1.08) translate(0,0);}to{transform:scale(1.0) translate(-1%,1%);}}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(12,15,26,.9) 0%,rgba(12,15,26,.45) 55%,rgba(12,15,26,.75) 100%),linear-gradient(to top,rgba(12,15,26,1) 0%,transparent 40%);}
.hero-glow{position:absolute;inset:0;background:radial-gradient(ellipse 55% 65% at 75% 30%,rgba(14,165,233,.2) 0%,transparent 60%),radial-gradient(ellipse 40% 50% at 15% 75%,rgba(16,185,129,.16) 0%,transparent 55%);animation:glowPulse 6s ease-in-out infinite alternate;}
@keyframes glowPulse{from{opacity:.6;}to{opacity:1;}}
.hero-content{position:relative;z-index:2;max-width:850px;padding:140px 80px 100px;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(90deg,var(--emerald),var(--sky));padding:7px 20px;border-radius:100px;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;margin-bottom:28px;animation:fadeSlideDown .8s ease both;}
.hero-title{font-family:'Oswald',sans-serif;font-size:clamp(64px,9vw,130px);font-weight:700;line-height:.92;text-transform:uppercase;margin-bottom:12px;animation:fadeSlideDown .8s .1s ease both;}
.hero-title .t1{color:#fff;}
.hero-title .t2{background:linear-gradient(90deg,var(--amber),var(--sundown),var(--crimson));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:block;}
.hero-sub{font-family:'Lora',serif;font-style:italic;font-size:clamp(16px,2vw,24px);color:rgba(255,255,255,.65);margin-bottom:26px;animation:fadeSlideDown .8s .2s ease both;}
.hero-desc{font-size:16px;line-height:1.8;color:rgba(255,255,255,.72);max-width:540px;margin-bottom:44px;animation:fadeSlideDown .8s .3s ease both;}
.hero-btns{display:flex;gap:16px;flex-wrap:wrap;animation:fadeSlideDown .8s .4s ease both;}
.btn-fire{background:linear-gradient(135deg,var(--sundown),var(--crimson));color:#fff;padding:16px 38px;font-family:'Oswald',sans-serif;font-weight:500;font-size:14px;letter-spacing:.18em;text-transform:uppercase;text-decoration:none;border-radius:4px;display:inline-block;transition:all .3s;box-shadow:0 8px 32px rgba(249,115,22,.4);}
.btn-fire:hover{transform:translateY(-3px);box-shadow:0 16px 48px rgba(249,115,22,.55);}
.btn-glass{background:rgba(255,255,255,.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.3);color:#fff;padding:16px 38px;font-family:'Oswald',sans-serif;font-weight:500;font-size:14px;letter-spacing:.18em;text-transform:uppercase;text-decoration:none;border-radius:4px;display:inline-block;transition:all .3s;}
.btn-glass:hover{border-color:var(--amber);color:var(--amber);}

/* Profile floating card */
.hero-profile{position:absolute;right:80px;bottom:90px;z-index:3;display:flex;align-items:center;gap:18px;background:rgba(12,15,26,.78);backdrop-filter:blur(16px);border:1px solid rgba(245,158,11,.45);border-radius:12px;padding:18px 26px;animation:fadeUp 1s .6s ease both;}
.profile-photo{width:70px;height:70px;border-radius:50%;object-fit:cover;object-position:top;border:3px solid var(--amber);}
.profile-name{font-family:'Oswald',sans-serif;font-size:18px;font-weight:700;}
.profile-handle{font-size:12px;color:var(--amber);letter-spacing:.05em;margin:3px 0 10px;}
.profile-socials{display:flex;gap:7px;}
.psoc{background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);font-size:11px;font-weight:700;padding:4px 10px;border-radius:100px;text-decoration:none;transition:background .2s;}
.psoc:hover{background:var(--amber);color:var(--ink);}

.scroll-hint{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:6px;font-family:'Oswald',sans-serif;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.35);animation:fadeUp 1.5s 1s ease both;}
.scroll-line{width:2px;height:40px;background:linear-gradient(to bottom,var(--amber),transparent);animation:scrollAnim 2s ease-in-out infinite;}
@keyframes scrollAnim{0%,100%{opacity:.3;}50%{opacity:1;}}

/* TICKER */
.ticker-wrap{overflow:hidden;background:linear-gradient(90deg,var(--emerald),var(--sky),#7c3aed,var(--sundown),var(--emerald));background-size:300% 100%;animation:gradFlow 8s ease infinite;}
@keyframes gradFlow{0%{background-position:0% 50%;}50%{background-position:100% 50%;}100%{background-position:0% 50%;}}
.ticker-track{display:flex;white-space:nowrap;animation:ticker 22s linear infinite;padding:14px 0;}
@keyframes ticker{from{transform:translateX(0);}to{transform:translateX(-50%);}}
.tick{display:inline-flex;align-items:center;gap:10px;margin:0 36px;font-family:'Oswald',sans-serif;font-size:13px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;}
.tick-dot{width:5px;height:5px;background:rgba(255,255,255,.5);border-radius:50%;}

/* GALLERY STRIP */
.gallery{display:grid;grid-template-columns:1.7fr 1fr 1fr 1fr;height:420px;gap:4px;}
.gcell{position:relative;overflow:hidden;cursor:pointer;}
.gcell img{width:100%;height:100%;object-fit:cover;transition:transform .6s ease;filter:saturate(1.25) contrast(1.05);}
.gcell:hover img{transform:scale(1.1);}
.gcell-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,15,26,.8) 0%,transparent 55%);display:flex;align-items:flex-end;padding:18px 20px;}
.gcell-label{font-family:'Oswald',sans-serif;font-size:16px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;text-shadow:0 2px 8px rgba(0,0,0,.7);}
.loc-pill{position:absolute;top:14px;left:14px;background:rgba(12,15,26,.7);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.2);border-radius:100px;padding:5px 14px;font-size:11px;font-weight:700;letter-spacing:.1em;color:var(--amber);text-transform:uppercase;}

/* ABOUT */
.about{padding:110px 80px;display:grid;grid-template-columns:1fr 1.1fr;gap:90px;align-items:center;max-width:1440px;margin:0 auto;}
.about-visual{position:relative;}
.about-main-img{width:100%;height:580px;object-fit:cover;object-position:top;border-radius:10px;filter:saturate(1.1);}
.about-accent-img{position:absolute;bottom:-32px;right:-32px;width:210px;height:210px;object-fit:cover;border-radius:10px;border:5px solid var(--ink);filter:saturate(1.2);}
.about-badge{position:absolute;top:22px;left:22px;background:rgba(12,15,26,.82);backdrop-filter:blur(12px);border:1px solid rgba(245,158,11,.5);border-radius:10px;padding:16px 22px;}
.badge-num{font-family:'Oswald',sans-serif;font-size:38px;font-weight:700;background:linear-gradient(135deg,var(--amber),var(--sundown));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;}
.badge-lbl{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-top:4px;}
.chip{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(90deg,rgba(16,185,129,.18),rgba(14,165,233,.18));border:1px solid rgba(16,185,129,.4);border-radius:100px;padding:7px 18px;font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--emerald);margin-bottom:22px;}
.about-h{font-family:'Oswald',sans-serif;font-size:clamp(36px,3.5vw,56px);font-weight:700;text-transform:uppercase;line-height:1.08;margin-bottom:26px;}
.about-h .grad-sky{background:linear-gradient(90deg,var(--sky),var(--emerald));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.about-article p{font-size:15px;line-height:1.85;color:rgba(255,255,255,.67);margin-bottom:18px;}
.about-article strong{color:#fff;font-weight:700;}
.pull-quote{margin:28px 0;padding:22px 26px;background:linear-gradient(135deg,rgba(14,165,233,.1),rgba(16,185,129,.08));border-left:4px solid var(--sky);border-radius:0 8px 8px 0;}
.pull-quote p{font-family:'Lora',serif;font-size:19px!important;font-style:italic;color:#fff!important;line-height:1.55!important;margin:0!important;}

/* DESTINATIONS */
.dest-section{background:linear-gradient(160deg,#0c0f1a 0%,#0a1628 50%,#0c0f1a 100%);padding:100px 80px;}
.sec-header{text-align:center;margin-bottom:56px;}
.sec-tag{display:inline-block;font-family:'Oswald',sans-serif;font-size:11px;letter-spacing:.35em;text-transform:uppercase;color:var(--sky);margin-bottom:16px;}
.sec-title{font-family:'Oswald',sans-serif;font-size:clamp(36px,4vw,58px);font-weight:700;text-transform:uppercase;line-height:1.05;margin-bottom:14px;}
.sec-title .grad-amber{background:linear-gradient(90deg,var(--amber),var(--sundown));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.sec-sub{font-size:15px;color:rgba(255,255,255,.48);max-width:500px;margin:0 auto;line-height:1.7;}
.dest-mosaic{display:grid;grid-template-columns:1fr 1fr 1fr;grid-template-rows:280px 280px;gap:6px;}
.dest-mosaic .dcell:first-child{grid-row:1/3;}
.dcell{position:relative;overflow:hidden;border-radius:6px;}
.dcell img{width:100%;height:100%;object-fit:cover;transition:transform .7s ease;filter:saturate(1.25) contrast(1.08);}
.dcell:hover img{transform:scale(1.1);}
.dcell-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,15,26,.88) 0%,rgba(12,15,26,.08) 60%);display:flex;flex-direction:column;justify-content:flex-end;padding:26px;}
.dcell-name{font-family:'Oswald',sans-serif;font-size:22px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;}
.dcell-region{font-size:12px;color:var(--amber);font-weight:600;letter-spacing:.12em;text-transform:uppercase;}
.dcell-icon{position:absolute;top:18px;right:18px;font-size:24px;filter:drop-shadow(0 2px 8px rgba(0,0,0,.5));}

/* PLATFORMS */
.platforms-section{padding:100px 80px;max-width:1440px;margin:0 auto;}
.plat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:56px;}
.pcard{position:relative;border-radius:14px;padding:40px 28px;text-align:center;text-decoration:none;overflow:hidden;border:1px solid rgba(255,255,255,.08);transition:transform .35s,box-shadow .35s;}
.pcard:hover{transform:translateY(-8px);}
.pcard-glow{position:absolute;inset:0;border-radius:14px;opacity:.1;transition:opacity .3s;}
.pcard:hover .pcard-glow{opacity:.22;}
.pcard.tk{background:rgba(105,201,208,.07);}
.pcard.tk .pcard-glow{background:radial-gradient(ellipse at top,#69C9D0,transparent);}
.pcard.tk:hover{box-shadow:0 24px 64px rgba(105,201,208,.28);}
.pcard.yt{background:rgba(255,0,0,.07);}
.pcard.yt .pcard-glow{background:radial-gradient(ellipse at top,#FF0000,transparent);}
.pcard.yt:hover{box-shadow:0 24px 64px rgba(255,0,0,.28);}
.pcard.ig{background:rgba(225,48,108,.07);}
.pcard.ig .pcard-glow{background:radial-gradient(ellipse at top,#E1306C,transparent);}
.pcard.ig:hover{box-shadow:0 24px 64px rgba(225,48,108,.28);}
.pcard.fb{background:rgba(24,119,242,.07);}
.pcard.fb .pcard-glow{background:radial-gradient(ellipse at top,#1877F2,transparent);}
.pcard.fb:hover{box-shadow:0 24px 64px rgba(24,119,242,.28);}
.pcard-icon{font-size:42px;margin-bottom:18px;position:relative;z-index:1;}
.pcard-name{font-family:'Oswald',sans-serif;font-size:20px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#fff;margin-bottom:6px;position:relative;z-index:1;}
.pcard-handle{font-size:12px;color:rgba(255,255,255,.45);margin-bottom:18px;position:relative;z-index:1;}
.pcard-desc{font-size:13px;line-height:1.7;color:rgba(255,255,255,.52);position:relative;z-index:1;}

/* SCENERY BANNER */
.scenery-banner{position:relative;height:480px;overflow:hidden;}
.scenery-bg{position:absolute;inset:-80px;background:url('https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1920&q=85') center/cover no-repeat;filter:saturate(1.35) contrast(1.05);}
.scenery-cover{position:absolute;inset:0;background:linear-gradient(to right,rgba(12,15,26,.92) 0%,rgba(12,15,26,.48) 55%,rgba(12,15,26,.72) 100%),linear-gradient(to bottom,rgba(12,15,26,.4) 0%,transparent 40%,rgba(12,15,26,.4) 100%);}
.scenery-content{position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:0 80px;max-width:700px;}
.scenery-tag{font-family:'Oswald',sans-serif;font-size:11px;letter-spacing:.35em;text-transform:uppercase;color:var(--emerald);margin-bottom:18px;}
.scenery-quote{font-family:'Lora',serif;font-size:clamp(22px,3vw,38px);font-style:italic;line-height:1.4;color:#fff;margin-bottom:28px;}
.scenery-quote strong{font-family:'Oswald',sans-serif;font-style:normal;font-weight:700;color:var(--amber);}

/* LEAD MAGNET */
.lead-section{padding:110px 80px;max-width:1440px;margin:0 auto;display:grid;grid-template-columns:1.1fr 1fr;gap:80px;align-items:center;}
.lead-h{font-family:'Oswald',sans-serif;font-size:clamp(36px,4vw,62px);font-weight:700;text-transform:uppercase;line-height:1.05;margin-bottom:18px;}
.lead-h .fire{background:linear-gradient(90deg,var(--sundown),var(--crimson));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.lead-sub{font-size:15px;line-height:1.8;color:rgba(255,255,255,.58);margin-bottom:32px;max-width:520px;}
.perks{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:36px;}
.perk{display:flex;gap:12px;padding:16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;transition:all .3s;}
.perk:hover{background:rgba(14,165,233,.08);border-color:rgba(14,165,233,.3);}
.perk-icon{font-size:22px;flex-shrink:0;}
.perk-txt{font-size:13px;line-height:1.55;color:rgba(255,255,255,.65);font-weight:500;}
.form-card{background:linear-gradient(145deg,rgba(255,255,255,.07),rgba(255,255,255,.03));border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:46px 38px;position:relative;overflow:hidden;}
.form-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--emerald),var(--sky),#7c3aed,var(--sundown));background-size:200% 100%;animation:gradFlow 4s ease infinite;}
.form-tag{position:absolute;top:18px;right:18px;background:linear-gradient(135deg,var(--amber),var(--sundown));color:var(--ink);font-family:'Oswald',sans-serif;font-weight:700;font-size:10px;letter-spacing:.2em;text-transform:uppercase;padding:4px 14px;border-radius:100px;}
.form-h{font-family:'Oswald',sans-serif;font-size:24px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;}
.form-sub{font-size:13px;color:rgba(255,255,255,.4);margin-bottom:26px;line-height:1.6;}
.finput{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;color:#fff;padding:14px 18px;font-family:'Montserrat',sans-serif;font-size:14px;outline:none;margin-bottom:11px;transition:border-color .2s,background .2s;}
.finput::placeholder{color:rgba(255,255,255,.28);}
.finput:focus{border-color:var(--sky);background:rgba(14,165,233,.08);}
.fsel{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;color:rgba(255,255,255,.7);padding:14px 18px;font-family:'Montserrat',sans-serif;font-size:14px;outline:none;margin-bottom:11px;appearance:none;cursor:pointer;}
.fsel option{background:#1a1a2e;color:#fff;}
.fsub{width:100%;background:linear-gradient(135deg,var(--emerald),var(--sky));color:#fff;border:none;border-radius:8px;padding:18px;font-family:'Oswald',sans-serif;font-weight:700;font-size:15px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;transition:all .3s;margin-top:4px;box-shadow:0 8px 32px rgba(16,185,129,.35);}
.fsub:hover{transform:translateY(-2px);box-shadow:0 16px 48px rgba(16,185,129,.5);}
.form-note{font-size:11px;color:rgba(255,255,255,.23);text-align:center;margin-top:12px;line-height:1.55;}

/* SERVICES */
.services{background:linear-gradient(135deg,#0a1628 0%,#0c0f1a 100%);padding:100px 80px;}
.services-inner{max-width:1440px;margin:0 auto;}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px;}
.scard{border-radius:12px;padding:44px 34px;position:relative;overflow:hidden;border:1px solid rgba(255,255,255,.08);transition:all .35s;}
.scard:nth-child(1){background:linear-gradient(145deg,rgba(14,165,233,.1),rgba(14,165,233,.02));}
.scard:nth-child(2){background:linear-gradient(145deg,rgba(16,185,129,.1),rgba(16,185,129,.02));}
.scard:nth-child(3){background:linear-gradient(145deg,rgba(245,158,11,.1),rgba(245,158,11,.02));}
.scard:nth-child(1):hover{border-color:rgba(14,165,233,.4);box-shadow:0 20px 60px rgba(14,165,233,.15);}
.scard:nth-child(2):hover{border-color:rgba(16,185,129,.4);box-shadow:0 20px 60px rgba(16,185,129,.15);}
.scard:nth-child(3):hover{border-color:rgba(245,158,11,.4);box-shadow:0 20px 60px rgba(245,158,11,.15);}
.scard:hover{transform:translateY(-6px);}
.scard-num{font-family:'Oswald',sans-serif;font-size:80px;font-weight:700;position:absolute;top:10px;right:18px;color:rgba(255,255,255,.04);line-height:1;}
.scard-icon{font-size:36px;margin-bottom:20px;}
.scard-name{font-family:'Oswald',sans-serif;font-size:20px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#fff;margin-bottom:14px;}
.scard-desc{font-size:14px;line-height:1.75;color:rgba(255,255,255,.53);}

/* CONTACT */
.contact{padding:110px 80px;max-width:1440px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:90px;align-items:center;}
.contact-h{font-family:'Oswald',sans-serif;font-size:clamp(36px,3.5vw,56px);font-weight:700;text-transform:uppercase;line-height:1.1;margin-bottom:18px;}
.contact-h .grad-fire{background:linear-gradient(90deg,var(--sundown),var(--crimson));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.contact-txt{font-size:15px;line-height:1.8;color:rgba(255,255,255,.56);margin-bottom:40px;}
.citems{display:flex;flex-direction:column;gap:13px;}
.citem{display:flex;align-items:center;gap:18px;padding:18px 22px;border-radius:10px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);text-decoration:none;color:#fff;transition:all .3s;}
.citem:hover{border-color:var(--amber);background:rgba(245,158,11,.07);transform:translateX(6px);}
.citem-ico{width:50px;height:50px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.citem-ico.wa{background:linear-gradient(135deg,#25D366,#128C7E);}
.citem-ico.ig{background:linear-gradient(135deg,#f09433,#dc2743,#bc1888);}
.citem-ico.tk{background:linear-gradient(135deg,#69C9D0,#010101);}
.citem-ico.yt{background:#FF0000;}
.citem-lbl{font-family:'Oswald',sans-serif;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.38);margin-bottom:3px;}
.citem-val{font-size:15px;font-weight:700;}
.contact-visual{position:relative;border-radius:16px;overflow:hidden;height:500px;}
