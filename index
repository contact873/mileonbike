<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Mile on Bike – Arfat Aziz. Pakistan's most authentic road storyteller. Follow jaw-dropping motorcycle adventures through Swat, Neelam Valley, Hunza & more. Get a free trip guide.">
<meta property="og:title" content="Mile on Bike | Arfat Aziz – Pakistan's Road Storyteller">
<meta property="og:description" content="Follow jaw-dropping motorcycle adventures through Pakistan's Northern Areas. Free trip planning guide available.">
<meta property="og:image" content="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1200&q=85">
<title>Mile on Bike | Arfat Aziz – Pakistan's Road Storyteller</title>

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

<!-- Instagram embed script -->
<script async src="//www.instagram.com/embed.js"></script>

<style>
/* ═══════════════════════════════════════
   DESIGN SYSTEM  –  "RAW ADVENTURE"
   Deep jewel-toned earth + neon vitality
═══════════════════════════════════════ */
:root {
  --forest:   #0d2b1f;
  --jade:     #1a5c3a;
  --lime:     #6dff6a;
  --gold:     #ffb800;
  --saffron:  #ff8c00;
  --crimson:  #e63946;
  --sky:      #48cae4;
  --snow:     #f8f5f0;
  --ink:      #0a0a0a;
  --mid:      rgba(255,255,255,0.55);
  --dim:      rgba(255,255,255,0.32);
}

*,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; font-size:16px; }
body {
  background: var(--ink);
  color: var(--snow);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  overflow-x: hidden;
  cursor: default;
}

/* ── CUSTOM CURSOR ── */
.cursor-dot {
  width: 8px; height: 8px;
  background: var(--lime);
  border-radius: 50%;
  position: fixed;
  top: 0; left: 0;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.15s ease;
  mix-blend-mode: screen;
}
.cursor-ring {
  width: 36px; height: 36px;
  border: 1.5px solid rgba(109,255,106,0.5);
  border-radius: 50%;
  position: fixed;
  top: 0; left: 0;
  pointer-events: none;
  z-index: 9998;
  transition: transform 0.25s ease, width 0.2s, height 0.2s, border-color 0.2s;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 500;
  padding: 0 64px;
  height: 68px;
  display: flex; align-items: center; justify-content: space-between;
  background: linear-gradient(to bottom, rgba(10,10,10,0.96) 0%, transparent 100%);
  backdrop-filter: blur(6px);
}
.nav-brand {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
  letter-spacing: 0.08em;
  color: var(--snow);
  text-decoration: none;
  display: flex; align-items: center; gap: 4px;
}
.nav-brand .dot { color: var(--lime); }
.nav-links { display: flex; align-items: center; gap: 36px; }
.nav-link {
  font-size: 12px; font-weight: 500;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--dim);
  text-decoration: none;
  transition: color 0.2s;
  position: relative;
}
.nav-link::after {
  content: '';
  position: absolute; bottom: -4px; left: 0;
  width: 0; height: 1px;
  background: var(--lime);
  transition: width 0.25s ease;
}
.nav-link:hover { color: var(--snow); }
.nav-link:hover::after { width: 100%; }
.nav-cta {
  background: var(--lime);
  color: var(--ink);
  padding: 10px 22px;
  font-size: 12px; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none;
  border-radius: 2px;
  transition: background 0.2s, transform 0.2s;
}
.nav-cta:hover { background: var(--gold); transform: translateY(-1px); }

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}

/* Left: large cinematic image */
.hero-left {
  position: relative;
  overflow: hidden;
}
.hero-left-img {
  position: absolute; inset: 0;
  background: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1400&q=90') center/cover no-repeat;
  animation: drift 20s ease-in-out infinite alternate;
  filter: saturate(1.3) contrast(1.1);
}
@keyframes drift {
  from { transform: scale(1.06) translate(0, 0); }
  to   { transform: scale(1.0)  translate(-2%, 2%); }
}
.hero-left-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(to right, transparent 60%, var(--ink) 100%),
    linear-gradient(to top,   var(--ink) 0%, transparent 35%);
}

/* Right: content panel */
.hero-right {
  position: relative;
  z-index: 2;
  display: flex; flex-direction: column; justify-content: center;
  padding: 100px 72px 80px 60px;
  background: linear-gradient(135deg, rgba(13,43,31,0.35) 0%, transparent 60%);
}

.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.3em; text-transform: uppercase;
  color: var(--lime);
  margin-bottom: 24px;
  animation: riseUp 0.9s cubic-bezier(0.22,1,0.36,1) both;
}
.hero-eyebrow-line {
  width: 36px; height: 1.5px;
  background: linear-gradient(90deg, var(--lime), transparent);
}

.hero-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(72px, 9vw, 136px);
  line-height: 0.9;
  letter-spacing: 0.03em;
  margin-bottom: 6px;
  animation: riseUp 0.9s 0.1s cubic-bezier(0.22,1,0.36,1) both;
}
.hero-title .t-green {
  background: linear-gradient(90deg, var(--lime), var(--sky));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hero-title .t-fire {
  background: linear-gradient(90deg, var(--gold), var(--saffron), var(--crimson));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

.hero-name {
  font-family: 'DM Serif Display', serif;
  font-style: italic;
  font-size: clamp(18px, 2.2vw, 26px);
  color: var(--mid);
  margin-bottom: 28px;
  animation: riseUp 0.9s 0.2s cubic-bezier(0.22,1,0.36,1) both;
}

.hero-desc {
  font-size: 15px; line-height: 1.85;
  color: rgba(248,245,240,0.65);
  max-width: 420px; margin-bottom: 44px;
  animation: riseUp 0.9s 0.3s cubic-bezier(0.22,1,0.36,1) both;
}

.hero-btns {
  display: flex; gap: 14px; flex-wrap: wrap;
  animation: riseUp 0.9s 0.4s cubic-bezier(0.22,1,0.36,1) both;
}

.btn-primary {
  background: var(--lime);
  color: var(--ink);
  padding: 16px 36px;
  font-size: 13px; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none;
  border-radius: 2px;
  transition: all 0.25s;
  box-shadow: 0 0 32px rgba(109,255,106,0.25);
}
.btn-primary:hover {
  background: var(--gold);
  box-shadow: 0 0 48px rgba(255,184,0,0.4);
  transform: translateY(-2px);
}
.btn-outline {
  border: 1.5px solid rgba(248,245,240,0.25);
  color: var(--snow);
  padding: 16px 36px;
  font-size: 13px; font-weight: 500;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none;
  border-radius: 2px;
  transition: all 0.25s;
  backdrop-filter: blur(8px);
}
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }

/* Hero stats bar */
.hero-stats {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  display: grid; grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid rgba(248,245,240,0.08);
  z-index: 3;
  animation: riseUp 0.9s 0.55s cubic-bezier(0.22,1,0.36,1) both;
}
.hstat {
  padding: 22px 0 22px 32px;
  border-right: 1px solid rgba(248,245,240,0.08);
  background: rgba(10,10,10,0.7);
  backdrop-filter: blur(12px);
}
.hstat:last-child { border-right: none; }
.hstat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px; letter-spacing: 0.05em;
  line-height: 1;
  background: linear-gradient(90deg, var(--gold), var(--lime));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hstat-lbl {
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--dim); margin-top: 4px;
}

/* ── LIVE TICKER ── */
.ticker {
  background: var(--jade);
  overflow: hidden; white-space: nowrap;
  position: relative;
}
.ticker-track {
  display: inline-flex;
  animation: scrollLeft 28s linear infinite;
  padding: 13px 0;
}
@keyframes scrollLeft { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.ticker-item {
  display: inline-flex; align-items: center; gap: 8px;
  margin: 0 48px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 15px; letter-spacing: 0.15em;
  color: rgba(255,255,255,0.9);
}
.ticker-sep { color: var(--lime); font-size: 18px; }

/* ── SECTION COMMONS ── */
.section { padding: 110px 80px; max-width: 1440px; margin: 0 auto; }
.section-full { padding: 110px 0; }

.label {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.3em; text-transform: uppercase;
  color: var(--lime);
  margin-bottom: 20px;
}
.label-line { width: 32px; height: 1.5px; background: var(--lime); }

.section-h {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(46px, 5vw, 80px);
  letter-spacing: 0.03em;
  line-height: 0.95;
  margin-bottom: 18px;
}
.section-h .accent {
  background: linear-gradient(90deg, var(--gold), var(--saffron));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.section-sub {
  font-size: 15px; line-height: 1.8;
  color: rgba(248,245,240,0.52);
  max-width: 520px;
}

/* ── PHOTO GALLERY MOSAIC ── */
.gallery-section {
  background: var(--forest);
  padding: 0;
}
.gallery-mosaic {
  display: grid;
  grid-template-columns: 1.8fr 1fr 1fr;
  grid-template-rows: 320px 320px;
  gap: 3px;
}
.gm-cell {
  position: relative; overflow: hidden;
}
.gm-cell.tall { grid-row: 1 / 3; }
.gm-cell img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.7s cubic-bezier(0.25,1,0.5,1);
  filter: saturate(1.3) contrast(1.08);
}
.gm-cell:hover img { transform: scale(1.07); }
.gm-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 55%);
  display: flex; flex-direction: column;
  justify-content: flex-end;
  padding: 22px 24px;
}
.gm-tag {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px; letter-spacing: 0.06em;
  color: #fff;
  text-shadow: 0 2px 12px rgba(0,0,0,0.6);
}
.gm-sub {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--gold);
  margin-top: 3px;
}
.loc-badge {
  position: absolute; top: 14px; left: 14px;
  background: rgba(10,10,10,0.72); backdrop-filter: blur(8px);
  border: 1px solid rgba(109,255,106,0.35);
  border-radius: 100px;
  padding: 5px 14px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--lime);
}

/* ── ABOUT ── */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: 90px;
  align-items: center;
}
.about-img-wrap {
  position: relative;
}
.about-img-main {
  width: 100%; aspect-ratio: 3/4;
  object-fit: cover; object-position: top;
  border-radius: 4px;
  filter: saturate(1.1);
}
.about-img-inset {
  position: absolute;
  bottom: -28px; right: -28px;
  width: 180px; height: 180px;
  object-fit: cover;
  border-radius: 4px;
  border: 4px solid var(--ink);
  filter: saturate(1.25);
}
.about-badge {
  position: absolute; top: 28px; left: 28px;
  background: rgba(10,10,10,0.82); backdrop-filter: blur(12px);
  border: 1px solid rgba(109,255,106,0.4);
  border-radius: 4px;
  padding: 18px 22px;
}
.about-badge-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 48px; letter-spacing: 0.04em;
  background: linear-gradient(135deg, var(--gold), var(--lime));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  line-height: 1;
}
.about-badge-l {
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--dim); margin-top: 4px;
}
.about-text {}
.about-h {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(36px, 3.8vw, 58px);
  line-height: 1.1;
  margin-bottom: 24px;
}
.about-h em { font-style: italic; color: var(--lime); }
.about-p {
  font-size: 15px; line-height: 1.88;
  color: rgba(248,245,240,0.66);
  margin-bottom: 18px;
}
.about-p strong { color: var(--snow); font-weight: 700; }
.blockquote {
  margin: 28px 0;
  padding: 22px 0 22px 26px;
  border-left: 3px solid var(--lime);
  background: linear-gradient(90deg, rgba(109,255,106,0.05), transparent);
  border-radius: 0 4px 4px 0;
}
.blockquote p {
  font-family: 'DM Serif Display', serif;
  font-style: italic;
  font-size: 20px; line-height: 1.55;
  color: var(--snow);
}
.dest-tags {
  display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px;
}
.dtag {
  border: 1px solid rgba(109,255,106,0.3);
  color: var(--lime);
  padding: 6px 16px;
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  border-radius: 2px;
  transition: all 0.2s;
}
.dtag:hover { background: var(--lime); color: var(--ink); }

/* ── SOCIAL MEDIA EMBEDS ── */
.embeds-bg {
  background: radial-gradient(ellipse at top, rgba(13,43,31,0.6) 0%, var(--ink) 70%);
  padding: 110px 0;
}
.embeds-inner { max-width: 1440px; margin: 0 auto; padding: 0 80px; }

.tabs {
  display: flex; gap: 4px;
  margin-bottom: 52px;
  border-bottom: 1px solid rgba(248,245,240,0.1);
  padding-bottom: 0;
}
.tab-btn {
  background: none; border: none;
  padding: 14px 28px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--dim);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.25s;
  position: relative;
  bottom: -1px;
}
.tab-btn.active { color: var(--lime); border-bottom-color: var(--lime); }
.tab-btn:hover:not(.active) { color: var(--snow); }

.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* Instagram grid */
.ig-embed-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  align-items: start;
}
.ig-embed-grid .instagram-media {
  max-width: 100% !important;
  min-width: unset !important;
  margin: 0 !important;
  border-radius: 8px !important;
  overflow: hidden;
}

/* YouTube embed */
.yt-embeds {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 20px;
}
.yt-main { aspect-ratio: 16/9; }
.yt-side {
  display: flex; flex-direction: column; gap: 16px;
}
.yt-side-item { aspect-ratio: 16/9; }
.yt-frame {
  width: 100%; height: 100%;
  border: none; border-radius: 8px;
}
.yt-channel-cta {
  display: flex; align-items: center; gap: 16px;
  background: rgba(255,0,0,0.08);
  border: 1px solid rgba(255,0,0,0.2);
  border-radius: 8px;
  padding: 20px 24px;
  text-decoration: none;
  color: var(--snow);
  transition: all 0.3s;
}
.yt-channel-cta:hover { background: rgba(255,0,0,0.15); border-color: rgba(255,0,0,0.4); transform: translateY(-2px); }
.yt-logo { font-size: 32px; }
.yt-cta-text {}
.yt-cta-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,100,100,0.8); }
.yt-cta-name { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 0.05em; }
.yt-cta-sub { font-size: 12px; color: var(--dim); }
.btn-yt-sub {
  margin-left: auto;
  background: #FF0000;
  color: #fff;
  padding: 12px 24px;
  font-size: 13px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  border-radius: 4px;
  white-space: nowrap;
  transition: background 0.2s;
}
.yt-channel-cta:hover .btn-yt-sub { background: #cc0000; }

/* TikTok embeds */
.tt-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  align-items: start;
}
.tt-embed-wrap {
  display: flex; flex-direction: column; gap: 12px;
}
.tt-embed-wrap blockquote {
  margin: 0 !important;
  border-radius: 8px !important;
  overflow: hidden;
}
/* TikTok follow CTA */
.tt-follow-cta {
  grid-column: 1/-1;
  margin-top: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  background: rgba(105,201,208,0.07);
  border: 1px solid rgba(105,201,208,0.2);
  border-radius: 8px;
  padding: 20px 32px;
}
.tt-icon { font-size: 28px; }
.tt-follow-text { font-size: 16px; color: var(--snow); }
.tt-follow-text strong { color: #69C9D0; }
.btn-tt {
  background: linear-gradient(135deg, #69C9D0, #010101);
  color: #fff;
  padding: 12px 28px;
  font-size: 13px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  border-radius: 4px;
  text-decoration: none;
  transition: opacity 0.2s;
}
.btn-tt:hover { opacity: 0.85; }

/* Social connect cards */
.social-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 3px;
  margin-top: 3px;
}
.scard {
  padding: 40px 32px;
  text-decoration: none;
  display: block;
  position: relative;
  overflow: hidden;
  transition: transform 0.3s;
}
.scard::before {
  content: '';
  position: absolute; inset: 0;
  opacity: 0; transition: opacity 0.3s;
}
.scard:hover { transform: translateY(-4px); }
.scard:hover::before { opacity: 1; }
.scard.ig { background: rgba(225,48,108,0.08); border-top: 2px solid #E1306C; }
.scard.ig::before { background: rgba(225,48,108,0.06); }
.scard.yt { background: rgba(255,0,0,0.08); border-top: 2px solid #FF0000; }
.scard.yt::before { background: rgba(255,0,0,0.06); }
.scard.tt { background: rgba(105,201,208,0.08); border-top: 2px solid #69C9D0; }
.scard.tt::before { background: rgba(105,201,208,0.06); }
.scard.fb { background: rgba(24,119,242,0.08); border-top: 2px solid #1877F2; }
.scard.fb::before { background: rgba(24,119,242,0.06); }
.scard-icon { font-size: 36px; margin-bottom: 16px; position: relative; z-index: 1; }
.scard-platform {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px; letter-spacing: 0.08em;
  color: var(--snow); margin-bottom: 4px;
  position: relative; z-index: 1;
}
.scard-handle {
  font-size: 12px; color: var(--dim);
  margin-bottom: 16px;
  position: relative; z-index: 1;
}
.scard-desc {
  font-size: 13px; line-height: 1.7;
  color: rgba(248,245,240,0.5);
  position: relative; z-index: 1;
}
.scard-arrow {
  position: absolute; bottom: 24px; right: 24px;
  font-size: 24px; color: rgba(248,245,240,0.15);
  transition: all 0.3s;
}
.scard:hover .scard-arrow { color: var(--lime); transform: translate(3px,-3px); }

/* ── PARALLAX QUOTE BANNER ── */
.quote-banner {
  position: relative; height: 500px; overflow: hidden;
}
.qb-img {
  position: absolute; inset: -100px;
  background: url('https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1920&q=90') center/cover no-repeat;
  filter: saturate(1.35) contrast(1.1);
  will-change: transform;
}
.qb-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(90deg, rgba(10,10,10,0.94) 0%, rgba(10,10,10,0.6) 50%, rgba(10,10,10,0.85) 100%),
    linear-gradient(to bottom, rgba(10,10,10,0.5) 0%, transparent 40%, rgba(10,10,10,0.5) 100%);
}
