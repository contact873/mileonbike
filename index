  btn.style.background = 'linear-gradient(135deg,#25D366,#128C7E)';
  btn.disabled = true;
  setTimeout(() => {
    window.open('https://wa.me/923009414903?text=Hi%20Arfat!%20I%20just%20signed%20up%20for%20your%20free%20Pakistan%20travel%20guide.%20Looking%20forward%20to%20planning%20my%20trip%20with%20you!', '_blank');
  }, 700);
}

// Parallax scroll
window.addEventListener('scroll', () => {
  const sy = window.scrollY;
  const heroBg = document.querySelector('.hero-bg');
  if (heroBg) heroBg.style.transform = `scale(1.08) translateY(${sy * 0.28}px)`;
  const sb = document.querySelector('.scenery-banner');
  const sbg = document.querySelector('.scenery-bg');
  if (sb && sbg) {
    const off = sy - sb.offsetTop;
    sbg.style.transform = `translateY(${off * 0.18}px)`;
  }
});
</script>
