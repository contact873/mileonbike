<script>
/* ── Custom cursor ── */
const dot  = document.getElementById('cursorDot');
const ring = document.getElementById('cursorRing');
let mx=0, my=0, rx=0, ry=0;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  dot.style.transform  = `translate(${mx-4}px,${my-4}px)`;
});
(function movRing(){
  rx += (mx - rx) * 0.12;
  ry += (my - ry) * 0.12;
  ring.style.transform = `translate(${rx-18}px,${ry-18}px)`;
  requestAnimationFrame(movRing);
})();
document.querySelectorAll('a,button,.scard,.gm-cell').forEach(el => {
  el.addEventListener('mouseenter', () => {
    dot.style.transform += ' scale(2)';
    ring.style.width  = '52px';
    ring.style.height = '52px';
    ring.style.borderColor = 'rgba(255,184,0,0.6)';
  });
  el.addEventListener('mouseleave', () => {
    ring.style.width  = '36px';
    ring.style.height = '36px';
    ring.style.borderColor = 'rgba(109,255,106,0.5)';
  });
});

/* ── Scroll reveal ── */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.08, rootMargin: '0px 0px -48px 0px' });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

/* Stagger children */
document.querySelectorAll('.social-cards,.svc-grid,.gallery-mosaic,.clinks,.hero-stats').forEach(parent => {
  [...parent.children].forEach((c,i) => { c.style.transitionDelay = `${i*0.08}s`; });
});

/* ── Tab switching ── */
function switchTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
  // Re-process Instagram embeds when tab switches
  if(id === 'instagram' && window.instgrm) window.instgrm.Embeds.process();
}

/* ── Parallax quote banner ── */
const qbImg = document.getElementById('qbImg');
window.addEventListener('scroll', () => {
  const banner = document.querySelector('.quote-banner');
  if (!banner) return;
  const off = window.scrollY - banner.offsetTop;
  if (qbImg) qbImg.style.transform = `translateY(${off * 0.22}px)`;
});

